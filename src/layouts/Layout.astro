---
import Footer from "../components/Footer.astro";
import Navigation from "../components/Navigation.astro";
import { getLang } from "../i18n";
import "../styles/global.css";

interface Props {
  lang?: string;
  description?: string;
}

const { lang = "en", description } = Astro.props as Props;
const t = getLang(lang);

const metaDescription = description || t.metaDescription;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simon Júlia - Web developer</title>
    <meta name="description" content={metaDescription} />
    <!-- favicon-->
    <link rel="shortcut icon" href="/favicon/simonJ.svg" type="image/x-icon">
    <link rel="icon" href="/favicon/simonJ.svg?" type="image/x-icon">
  </head>

  <body>
    <header class="header">
        <Navigation lang={lang} />
    </header>
    <main>
      <slot />
    </main>

    <Footer lang={lang} />
  </body>
</html>

<style>
    body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: #f1f1f1;
    }

    .header {
        position: fixed;
        width: 100%;
        top: 0;
        z-index: 99;
    }

    main {
        flex: 1;
        margin-top: 5rem; /* Should be the header's height */ 
    }
</style>
