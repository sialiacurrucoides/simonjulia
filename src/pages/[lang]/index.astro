---
import AboutMe from "../../components/AboutMe.astro";
import DigitalGarden from "../../components/DigitalGarden.astro";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "hu" } }
  ];
}



const { lang } = Astro.params;
---

<Layout lang={lang}>
  <DigitalGarden lang={lang} />
  <AboutMe lang={lang} />
</Layout>