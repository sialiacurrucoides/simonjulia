---
import { Image } from "astro:assets";
import { getLang } from "../i18n";
import type { Article } from "../types";
import digitalGardenImage from "../assets/digital_garden.svg";
import PostLinkItem from "./PostLinkItem.astro";
import TagList from "./TagList.astro";

const articlesHU: Article[] = Object.values(import.meta.glob('../content/blog/hu/*.md', { eager: true }));
const articlesEN: Article[] = Object.values(import.meta.glob('../content/blog/en/*.md', { eager: true }));

const { lang = "en" } = Astro.params;
const t = getLang(lang);

const sortedArticlesHU = [...articlesHU].sort(
  (a, b) => b.frontmatter.date.localeCompare(a.frontmatter.date)
);

const sortedArticlesEN = [...articlesEN].sort(
  (a, b) => b.frontmatter.date.localeCompare(a.frontmatter.date)
);

const tagsHU = [
  ...new Set(sortedArticlesHU.flatMap(article => article.frontmatter.tags))
];

const tagsEN = [
  ...new Set(sortedArticlesEN.flatMap(article => article.frontmatter.tags))
];

const tags = lang === "hu" ? tagsHU : tagsEN;
---
<section id="blog" class="light-theme">
    <div class="inner-container">
        <h1 class="title">{t.nav.blog}</h1>
        <p class="definition">{t.digitalGarden.definition}</p>
        <p class="introduction">{t.digitalGarden.introduction}</p>
        <div class="content-container">
            <aside class="image-container">
                <Image 
                    src={digitalGardenImage} 
                    alt="A digital garden" 
                    class="digital-garden-image" 
                    sizes="(max-width: 800px) 100vw, 300px"
                    loading="eager"
                    fetchpriority="high"
                />
            </aside>
            <div class="list-container">
                <TagList tags={tags}/>
                <div class="post-list-wrapper">
                    <ul class="post-list" tabindex="0" aria-label="List of blog posts">
                        {(lang === "hu" ? sortedArticlesHU : sortedArticlesEN).map((article) => (
                            <PostLinkItem title={article.frontmatter.title} date={article.frontmatter.date} slug={article.file.split(`${lang}/`)[1].replace(".md", "")} lang={lang} />
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    #blog {
        width: 100%;
        display: flex;
        justify-content: center;
        scroll-margin-top: 5rem;
    }
    
    .post-list-wrapper {
        position: relative;
    }

    /* scrolling element */
    .post-list {
        list-style: none;
        max-height: 260px;
        overflow-y: auto;
        padding: 0.75rem;
        background-color: var(--main-bg-color-lightest);
        border-radius: 8px;
        scrollbar-gutter: stable;
    }

    .post-list-wrapper:focus {
        outline: 2px solid var(--accent-color);
        outline-offset: 2px;
    }

    /* TOP shadow */
    .post-list-wrapper::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 24px;
        pointer-events: none;
        background: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0.12),
            rgba(0, 0, 0, 0)
        );
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    /* BOTTOM shadow */
    .post-list-wrapper::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 24px;
        pointer-events: none;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.15),
            rgba(0, 0, 0, 0)
        );
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    /* states */
    .post-list-wrapper.has-top-shadow::before {
        opacity: 1;
    }

    .post-list-wrapper.has-bottom-shadow::after {
        opacity: 1;
    }

    .post-list li {
        margin-bottom: 1em;
    }

    .title {
        margin-top: 2rem;
    }

    .definition {
        font-style: italic;
        padding: 1rem 0;
        color: var(--main-bg-color);
    }

    .introduction {
        padding-bottom: 2rem;
    }

    .content-container {
        display: grid;
        grid-template-columns: 1fr 2fr;
    }  

    .post-list {
        margin-top: 1rem;
    }
    
    .image-container, .list-container {
        display: inline-block;
        padding: 1rem;
    }

    .image-container {
        display: flex;
        max-height: fit-content;
        width: 300px;
        justify-content: center;
        align-items: center;
        align-self: center;
        border-radius: 8px;
        background: #6b4a2b;
        box-shadow:
            0 10px 25px rgba(0,0,0,0.4),
            0 3px 8px rgba(0,0,0,0.25),
            inset 0 2px 3px rgba(255,255,255,0.15),
            inset 0 -3px 6px rgba(0,0,0,0.25);
    }

    .digital-garden-image {
        max-width: 300px;
        width: 100%;
        height: auto;
        box-shadow: inset 0 2px 6px rgba(0,0,0,0.35);
    }

    @media (max-width: 800px) {
        .content-container {
            grid-template-columns: 1fr;
        }
    }

</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
    const list = document.querySelector(".post-list") as HTMLElement | null;

    if (!list) return;

    const wrapper = document.querySelector(".post-list-wrapper");

    if (!wrapper){
        return;
    }

    if (!list || !wrapper) return;

    function updateShadows() {
        const { scrollTop, scrollHeight, clientHeight } = list as HTMLElement;

        const hasOverflow = scrollHeight > clientHeight;
        const isAtTop = scrollTop <= 0;
        const isAtBottom = scrollTop + clientHeight >= scrollHeight - 1;

        wrapper?.classList.toggle("has-top-shadow", hasOverflow && !isAtTop);
        wrapper?.classList.toggle("has-bottom-shadow", hasOverflow && !isAtBottom);
    }

    list.addEventListener("scroll", updateShadows);
    window.addEventListener("resize", updateShadows);

    updateShadows();
});
</script>