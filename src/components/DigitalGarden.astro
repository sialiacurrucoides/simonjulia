---
import { Image } from "astro:assets";
import { getLang } from "../i18n";
import type { Article } from "../types";
import digitalGardenImage from "../assets/digital_garden.svg";
import PostLinkItem from "./PostLinkItem.astro";
import TagList from "./TagList.astro";

const articlesHU: Article[] = Object.values(import.meta.glob('../content/blog/hu/*.md', { eager: true }));
const articlesEN: Article[] = Object.values(import.meta.glob('../content/blog/en/*.md', { eager: true }));

const { lang = "en" } = Astro.props;
const t = getLang(lang);

const tagsHU = [...new Set(articlesHU.map((article) => article.frontmatter.tags).flat())];
const tagsEN = [...new Set(articlesEN.map((article) => article.frontmatter.tags).flat())];
const tags = lang === "hu" ? tagsHU : tagsEN;
---
<section id="blog">
  <h1>{t.nav.blog}</h1>
  <p class="definition">{t.digitalGarden.definition}</p>
  <p class="introduction">{t.digitalGarden.introduction}</p>
  <div class="content-container">
    <aside class="image-container">
        <Image src={digitalGardenImage} alt="A digital garden" width={300} height={300} class="digital-garden-image"/>
    </aside>
    <div class="list-container">
        <TagList tags={tags}/>
        <ul class="post-list">
            {(lang === "hu" ? articlesHU : articlesEN).map((article) => (
                <PostLinkItem title={article.frontmatter.title} date={article.frontmatter.date} slug={article.file.split(`${lang}/`)[1].replace(".md", "")} lang={lang} />
            ))}
        </ul>
    </div>
  </div>
</section>

<style>
    #blog {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2em;
        padding-top: 8rem;
    }
    
    #blog ul {
        list-style: none;
        padding: 0;
    }
    
    #blog li {
        margin-bottom: 1em;
    }

    .definition {
        font-style: italic;
        padding: 1rem 0;
        color: var(--main-bg-color);
    }

    .introduction {
        padding-bottom: 2rem;
    }

    .content-container {
        display: grid;
        grid-template-columns: 1fr 2fr;
    }  

    .post-list {
        margin-top: 1rem;
    }
    
    .image-container, .list-container {
        display: inline-block;
        padding: 1rem;
    }

    .image-container {
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 8px;
        background: #6b4a2b;
        box-shadow:
            0 10px 25px rgba(0,0,0,0.4),
            0 3px 8px rgba(0,0,0,0.25),
            inset 0 2px 3px rgba(255,255,255,0.15),
            inset 0 -3px 6px rgba(0,0,0,0.25);
    }

    .digital-garden-image {
        max-width: 100%;
        height: auto;
        box-shadow: inset 0 2px 6px rgba(0,0,0,0.35);
    }

    @media (max-width: 800px) {
        .content-container {
            grid-template-columns: 1fr;
        }
    }

</style>