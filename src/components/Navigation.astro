---
import { Picture } from "astro:assets";
import { getLang } from "../i18n";
import LanguageSelector from "./LanguageSelector.astro";

const { lang = "en" } = Astro.params;
const t = getLang(lang);
---
<nav class="nav">
    <div id="logo">
        <a href=`/${lang}`>
            <Picture src="/simon.webp" alt="Simon logo" width={26} height={40} formats={['avif', 'webp']} />
        </a>
    </div>
    <input class="hamburger-checkbox" type="checkbox" id="hamburger-icon" aria-hidden="true">

    <label for="hamburger-icon" class="hamburger" role="button" tabindex="0" aria-controls="nav-links" aria-expanded="false" aria-label="Menu">
        <svg class="mobileMenuIcon hamburger-open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <line x1="3" y1="6" x2="21" y2="6" stroke-width="2" stroke-linecap="round"/>
            <line x1="3" y1="12" x2="21" y2="12" stroke-width="2" stroke-linecap="round"/>
            <line x1="3" y1="18" x2="21" y2="18" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <svg class="mobileMenuIcon hamburger-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-label="close">
            <line x1="18" y1="6" x2="6" y2="18" stroke-width="2" stroke-linecap="round"/>
            <line x1="6" y1="6" x2="18" y2="18" stroke-width="2" stroke-linecap="round"/>
        </svg>
    </label>

    <div id="nav-links" class="nav-links">
        <a href=`/${lang}/#blog`>{t.nav.blog}</a>
        <a href=`/${lang}/#bio`>{t.nav.about}</a>
        <a href=`/${lang}/#projects`>{t.nav.projects}</a>
        <LanguageSelector lang={lang} />
    </div>
</nav>

<style>
    .nav {
        background-color: var(--main-bg-color);
        background-image: linear-gradient(to left, var(--darkest-blue), var(--main-bg-color));
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-right: 2rem;
        width: 100%;
        z-index: 20;
    }

    nav a {
        text-decoration: none;
        color: var(--soft-white);
    }

    .nav-links a {
        display: inline-flex;
        justify-content: center;
        padding: 1rem;
    }

    nav .nav-links a:hover {
        transform: scale(1.1);
        background-color: var(--main-bg-color-light);
        border-radius: 4px;
        color: white;
    }

    #logo {
        height: 3rem;
        width: 3rem;
        margin: 1rem 2rem;
        border-radius: 50%;
        background: #ccc;
        position: relative;
    }

    #logo img {
        height: 2.5rem;
        margin: 0.5rem 0 0 0.5rem;
        align-self: center;
    }

    .hamburger {
	position: absolute;
	right: 2rem;
	top: 1rem;
	width: 3rem;
	height: 3rem;
	padding: 0;
	border: none;
	background: transparent;
	color: rgba(255, 255, 255, 0.9);
	cursor: pointer;
	display: flex;
	justify-content: center;
	align-items: center;
}

	.hamburger:focus-visible {
		outline: 2px solid var(--soft-white);
		outline-offset: 2px;
	}

	.hamburger svg {
		width: 1.8rem;
		height: 1.8rem;
		color: currentColor;
	}

	.hamburger-checkbox {
		display: none;
	}

	/* checkbox + label + nav: works even if JS is disabled */
	#hamburger-icon:checked + .hamburger .hamburger-open {
		display: none;
	}

    .hamburger-close {
        display: none;
    }

	#hamburger-icon:checked + .hamburger .hamburger-close {
		display: block;
	}

	#hamburger-icon:checked + .hamburger + .nav-links {
		display: block;
		margin-top: 3rem;
		animation: unfold 0.6s ease-out;
	}

@media screen and (min-width: 800px) {
	.hamburger {
		display: none;
	}
}

@media (max-width: 800px) {
	nav {
		padding-right: 0;
		opacity: 0.95;
		border-bottom: 1px solid rgba(255, 255, 255, .6);
	}
	nav .nav-links {
		display: none;
		margin: auto;
		transform: translateX(-3rem);
	}

	nav .nav-links a {
		display: block;
		padding: 0.9rem 1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.3);
	}
	nav .nav-links a:last-of-type {
		border-bottom: none;
	}

	/* Using the checkbox + label pattern ensures the mobile menu works even when JS is disabled.
	   JS is only used to keep aria-expanded in sync and enable Enter/Space activation for the label. */

	@keyframes unfold {
		0% {
			opacity: 0;
		}
		100% {
			opacity: 1;
		}
	}
}
</style>

<script is:inline>
    window.addEventListener('load', () => {
        const checkbox = document.querySelector('#hamburger-icon');
        const toggle = document.querySelector('.hamburger');

        if (!checkbox || !toggle) return;

        const syncAria = () => {
            toggle.setAttribute('aria-expanded', String(checkbox.checked));
        };

        syncAria();
        checkbox.addEventListener('change', syncAria);

        toggle.addEventListener('keydown', (event) => {
            if (event.key === 'Enter') {
                event.preventDefault();
                checkbox.click();
            }
        });

        // Close on clicking a nav link
        document.querySelector('#nav-links')?.addEventListener('click', (e) => {
            if (e.target.tagName === 'A') {
                checkbox.checked = false;
                syncAria();
            }
        });

        // Close on hash navigation
        window.addEventListener('hashchange', () => {
            checkbox.checked = false;
            syncAria();
        });
    });
</script>