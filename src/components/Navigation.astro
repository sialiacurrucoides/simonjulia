---
import { Picture } from "astro:assets";
import { getLang } from "../i18n";
import LanguageSelector from "./LanguageSelector.astro";

const { lang = "en" } = Astro.props;
const t = getLang(lang);
---
<nav class="nav">
    <div id="logo">
        <a href=`/${lang}`>
            <Picture src="/simon.webp" alt="Simon logo" width={26} height={40} formats={['avif', 'webp']} />
        </a>
    </div>
    <div><label for="hamburger-icon" class="hamburger">
        <svg class="mobileMenuIcon hamburger-open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <line x1="3" y1="6" x2="21" y2="6" stroke-width="2" stroke-linecap="round"/>
            <line x1="3" y1="12" x2="21" y2="12" stroke-width="2" stroke-linecap="round"/>
            <line x1="3" y1="18" x2="21" y2="18" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <svg class="mobileMenuIcon hamburger-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display: none;">
            <line x1="18" y1="6" x2="6" y2="18" stroke-width="2" stroke-linecap="round"/>
            <line x1="6" y1="6" x2="18" y2="18" stroke-width="2" stroke-linecap="round"/>
        </svg>
    </label></div>
    <input type="checkbox" id="hamburger-icon">
    <div class="nav-links">
        <a href=`/${lang}/#blog`>{t.nav.blog}</a>
        <a href=`/${lang}/#bio`>{t.nav.about}</a>
        <a href=`/${lang}/#projects`>{t.nav.projects}</a>
        <LanguageSelector lang={lang} />
    </div>
</nav>

<style>
    .nav {
        background-color: var(--main-bg-color);
        background-image: linear-gradient(to left, var(--darkest-blue), var(--main-bg-color));
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-right: 2rem;
        width: 100%;
        z-index: 20;
    }

    nav a {
        text-decoration: none;
        color: var(--soft-white);
    }

    .nav-links a {
        display: inline-flex;
        justify-content: center;
        padding: 1rem;
    }

    nav .nav-links a:hover {
        transform: scale(1.1);
        background-color: var(--main-bg-color-light);
        border-radius: 4px;
        color: white;
    }

    #logo {
        height: 3rem;
        width: 3rem;
        margin: 1rem 2rem;
        border-radius: 50%;
        background: #ccc;
        position: relative;
    }

    #logo img {
        height: 2.5rem;
        margin: 0.5rem 0 0 0.5rem;
        align-self: center;
    }

    #hamburger-icon {
	display: none;
}

.hamburger {
	position: absolute;
	right: 2rem;
	top: 1rem;
	width: 3rem;
	text-align: center;
}

.hamburger i {
	color: rgba(255, 255, 255, 0.9);
	font-size: 1.8rem;
	cursor: pointer;
}

.hamburger svg {
	color: rgba(255, 255, 255, 0.9);
	width: 1.8rem;
	height: 1.8rem;
	cursor: pointer;
}

@media screen and (min-width: 800px) {
	.hamburger {
		display: none;
	}
}

@media (max-width: 800px) {
	nav {
		padding-right: 0;
		opacity: 0.95;
		border-bottom: 1px solid rgba(255, 255, 255, .6);
	}
	nav .nav-links {
		display: none;
		margin: auto;
		transform: translateX(-3rem);
	}
	nav .nav-links a {
		display: block;
		padding: 0.9rem 1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.3);
	}
	nav .nav-links a:last-of-type {
		border-bottom: none;
	}

	#hamburger-icon:checked + .nav-links {
		display: block;
		margin-top: 3rem;
		animation: unfold 0.6s ease-out;
	}

	@keyframes unfold {
		0% {
			opacity: 0;
		}
		100% {
			opacity: 1;
		}
	}
}
</style>

<script>
    window.onload = () => {
        const hamburgerCheckbox = document.querySelector('#hamburger-icon') as HTMLInputElement;
        const hamburgerOpen = document.querySelector('.hamburger-open') as SVGElement;
        const hamburgerClose = document.querySelector('.hamburger-close') as SVGElement;

        if (!hamburgerCheckbox || !hamburgerOpen || !hamburgerClose) return;

        const toggleIcon = () => {
            if (hamburgerCheckbox.checked) {
                hamburgerOpen.style.display = 'none';
                hamburgerClose.style.display = 'block';
            } else {
                hamburgerOpen.style.display = 'block';
                hamburgerClose.style.display = 'none';
            }
        };

        hamburgerCheckbox.addEventListener('change', toggleIcon);
    };
</script>